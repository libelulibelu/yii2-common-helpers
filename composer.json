{
  "name": "libelulibelu/yii2-common-helpers",
  "description": "Common helpers para yii2 y mongodb",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension",
    "helpers"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Johnny Garcia",
      "email": "johnnygar98@hotmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "yiisoft/yii2": "~2.0.54",
    "mongodb/mongodb": "^2.3",
    "yiisoft/yii2-mongodb": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "test": "phpunit",
    "post-install-cmd": "git config core.hooksPath .githooks",
    "post-update-cmd": "git config core.hooksPath .githooks"
  },
  "config": {
    "fxp-asset": {
      "enabled": false
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "autoload": {
    "psr-4": {
      "Libelula\\CommonHelpers\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Libelula\\CommonHelpers\\Tests\\": "tests"
    }
  }
}
